{
  "name": "nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm run build:docs && nuxt build",
    "build:docs": "pnpm --filter @comparadolar/docs run docs:build",
    "dev": "nuxt dev",
    "generate": "pnpm run build:docs && nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint --ext .js,.ts,.vue .",
    "lint:fix": "eslint --fix --ext .js,.ts,.vue .",
    "preview:og": "tsx scripts/preview-og.ts",
    "docs:dev": "pnpm --filter @comparadolar/docs run docs:dev"
  },
  "dependencies": {
    "@nuxt/eslint": "1.9.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/seo": "^3.4.0",
    "@nuxtjs/sitemap": "7.4.7",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@takumi-rs/core": "^0.71.7",
    "@takumi-rs/wasm": "^0.71.7",
    "@vueuse/nuxt": "^14.2.1",
    "@vueuse/router": "^14.2.1",
    "echarts": "^6.0.0",
    "eslint": "^9.39.1",
    "nuxt": "^4.1.3",
    "nuxt-echarts": "1.0.1",
    "nuxt-gtag": "4.0.0",
    "nuxt-og-image": "^6.0.0",
    "slugify": "^1.6.6",
    "vue": "^3.5.29",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3"
}
