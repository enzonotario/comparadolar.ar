                        "is24x7": true,
                        "url": "https://www.astropay.com/?ref=comparadolar",
                        "prettyName": "Astropay",
                        "slowChange": false,
                        "isBank": false
                      },
                      {
                        "slug": "balanz",
                        "name": "balanz",
                        "logoUrl": "https://api.argentinadatos.com/static/logos/balanz.png",
                        "is24x7": false,
                        "url": "https://balanz.com",
                        "prettyName": "Balanz",
                        "slowChange": false,
                        "isBank": false
                      },
                      {
                        "slug": "banco-ciudad",
                        "name": "banco ciudad",
                        "logoUrl": "https://api.argentinadatos.com/static/logos/banco-ciudad.png",
                        "is24x7": false,
                        "url": "https://bancociudad.com.ar/institucional/?ref=comparadolar",
                        "prettyName": "Banco Ciudad",
                        "slowChange": false,
                        "isBank": true
